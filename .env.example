# ─────────────────────────────────────────────────────────────────────────
#  ABCM — Variables d'environnement du back-office (Payload)
#  À renseigner dans le tableau de bord Vercel (Settings → Environment Variables).
# ─────────────────────────────────────────────────────────────────────────

# Secret de chiffrement Payload (sessions, tokens). OBLIGATOIRE en production.
# Générer une valeur aléatoire longue, ex. : openssl rand -base64 32
PAYLOAD_SECRET=

# URL de connexion Postgres — fournie par Supabase.
# Supabase → Project Settings → Database → Connection string → URI
# (utiliser le "Connection Pooler" / port 6543 pour le serverless Vercel).
# Ex. : postgresql://postgres.xxxx:MOT_DE_PASSE@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
DATABASE_URI=

# Stockage des médias en production (Vercel Blob).
# Vercel → Storage → Blob → créer un store → copier le token.
BLOB_READ_WRITE_TOKEN=

# URL publique du site (pour les liens absolus / previews). Optionnel.
# Ex. : https://abcm-preview.vercel.app
NEXT_PUBLIC_SITE_URL=

# ─────────────────────────────────────────────────────────────────────────
#  Envoi des e-mails du formulaire de contact (Resend)
# ─────────────────────────────────────────────────────────────────────────

# Clé API Resend. OBLIGATOIRE pour que les formulaires soient envoyés.
# Resend → API Keys → Create API Key. Ne jamais committer cette valeur.
RESEND_API_KEY=

# Destinataire(s) des demandes. Optionnel. Plusieurs adresses possibles,
# séparées par des virgules. Défaut : caroline@abcmperformances.com, audrey@abcm.io
CONTACT_EMAIL_TO=

# Expéditeur des e-mails. Optionnel mais RECOMMANDÉ en production.
# Doit appartenir à un domaine vérifié dans Resend (Resend → Domains).
# Défaut : "ABCM Performances <onboarding@resend.dev>" (domaine de test Resend,
# fonctionne sans configuration mais réservé aux essais).
# Ex. production : ABCM Performances <contact@abcmperformances.com>
CONTACT_EMAIL_FROM=
